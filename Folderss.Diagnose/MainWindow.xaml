<Window x:Class="Folderss.Diagnose.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:term="clr-namespace:EasyWindowsTerminalControl;assembly=EasyWindowsTerminalControl"
        xmlns:avalon="clr-namespace:AvalonDock;assembly=AvalonDock"
        xmlns:layout="clr-namespace:AvalonDock.Layout;assembly=AvalonDock"
        Title="Folderss 네이티브 터미널 진단 도구" Height="650" Width="1000"
        Background="#1e1e24">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel: AvalonDock containing Terminal Control in LayoutDocument (Tabbed) -->
        <Grid Grid.Column="0" Margin="0,0,5,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="터미널 문서 탭 패널 (드래그/도킹 가능)" Foreground="#ffffff" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="Gray" Margin="10,0,0,0" VerticalAlignment="Center" />
                <TextBlock x:Name="StatusLabel" Text="대기 중" Foreground="#aaaaaa" Margin="5,0,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <avalon:DockingManager x:Name="DockManager" Grid.Row="1" Background="#121214">
                <layout:LayoutRoot>
                    <layout:LayoutPanel Orientation="Vertical">
                        <layout:LayoutDocumentPane>
                            <layout:LayoutDocument x:Name="TerminalDock"
                                                   Title="터미널 PTY 세션"
                                                   ContentId="terminal"
                                                   CanClose="False">
                                <Border BorderBrush="#3f3f46" BorderThickness="1" Background="#000000">
                                    <term:EasyTerminalControl x:Name="TerminalControl" />
                                </Border>
                            </layout:LayoutDocument>
                        </layout:LayoutDocumentPane>
                    </layout:LayoutPanel>
                </layout:LayoutRoot>
            </avalon:DockingManager>
        </Grid>

        <!-- Right Panel: Diagnostics and Controls -->
        <Grid Grid.Column="1" Margin="5,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Test Controls -->
            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="진단 및 테스트 제어" Foreground="#ffffff" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" />
                
                <TextBlock Text="시작 디렉토리 설정:" Foreground="#aaaaaa" Margin="0,0,0,5" />
                <TextBox x:Name="DirInput" Text="C:\" Background="#2d2d30" Foreground="#ffffff" BorderBrush="#3f3f46" Padding="4" Margin="0,0,0,10" />

                <TextBlock Text="실행할 셸 프로그램:" Foreground="#aaaaaa" Margin="0,0,0,5" />
                <ComboBox x:Name="ShellSelect" SelectedIndex="0" Background="#2d2d30" Foreground="#000000" Margin="0,0,0,10">
                    <ComboBoxItem Content="Windows PowerShell (powershell.exe)" Tag="powershell.exe -NoLogo -NoProfile -NoExit" />
                    <ComboBoxItem Content="PowerShell 7 (pwsh.exe)" Tag="pwsh.exe -NoLogo -NoProfile -NoExit" />
                    <ComboBoxItem Content="Command Prompt (cmd.exe)" Tag="cmd.exe /Q /K" />
                </ComboBox>

                <Button Content="선택한 옵션으로 터미널 재시작 (RestartTerm)" Click="Restart_Click" Height="32" Background="#007acc" Foreground="#ffffff" FontWeight="Bold" BorderThickness="0" Margin="0,0,0,5" />
                <Button Content="직접 cd / Set-Location 쏘아보기 (WriteToTerm)" Click="SendCd_Click" Height="28" Background="#2d2d30" Foreground="#ffffff" BorderBrush="#3f3f46" Margin="0,0,0,15" />
            </StackPanel>

            <!-- Diagnostic Logs -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="실시간 이벤트/예외 진단 로그:" Foreground="#aaaaaa" Margin="0,0,0,5" />
                <TextBox Grid.Row="1" x:Name="LogBox" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Background="#121214" Foreground="#00ff00" FontFamily="Consolas" FontSize="11" Padding="5" BorderBrush="#3f3f46" />
            </Grid>

            <!-- Bottom Actions -->
            <StackPanel Grid.Row="2" Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="로그 지우기" Click="ClearLog_Click" Width="80" Height="26" Background="#2d2d30" Foreground="#ffffff" BorderBrush="#3f3f46" Margin="0,0,5,0" />
                <Button Content="로그 파일 저장" Click="SaveLog_Click" Width="100" Height="26" Background="#2d2d30" Foreground="#ffffff" BorderBrush="#3f3f46" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
