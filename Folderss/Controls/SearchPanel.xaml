<UserControl x:Class="Folderss.Controls.SearchPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 검색 입력 툴바 -->
        <Border Grid.Row="0"
                Padding="6,5"
                Background="{DynamicResource SurfaceBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- 범위 선택 -->
                <ComboBox x:Name="ScopeCombo"
                          DockPanel.Dock="Right"
                          Width="120"
                          Margin="4,0,0,0"
                          VerticalContentAlignment="Center"
                          SelectionChanged="ScopeCombo_SelectionChanged">
                    <ComboBoxItem Content="현재 폴더만" IsSelected="True" Tag="current"/>
                    <ComboBoxItem Content="하위 폴더 포함" Tag="recursive"/>
                </ComboBox>

                <!-- 옵션 토글 -->
                <ToggleButton x:Name="RegexToggle"
                              DockPanel.Dock="Right"
                              Style="{StaticResource CompactToggleButtonStyle}"
                              Content=".*"
                              ToolTip="정규식 사용"
                              Width="28"
                              Margin="4,0,0,0"
                              Checked="Option_Changed"
                              Unchecked="Option_Changed"/>
                <ToggleButton x:Name="CaseToggle"
                              DockPanel.Dock="Right"
                              Style="{StaticResource CompactToggleButtonStyle}"
                              Content="Aa"
                              ToolTip="대/소문자 구분"
                              Width="28"
                              Margin="4,0,0,0"
                              Checked="Option_Changed"
                              Unchecked="Option_Changed"/>

                <!-- 검색어 입력 -->
                <Grid>
                    <TextBox x:Name="QueryBox"
                             VerticalContentAlignment="Center"
                             Padding="4,2"
                             KeyDown="QueryBox_KeyDown"
                             TextChanged="QueryBox_TextChanged"/>
                    <TextBlock Text="검색어를 입력하세요 (Enter)"
                               IsHitTestVisible="False"
                               Foreground="{DynamicResource SecondaryText}"
                               VerticalAlignment="Center"
                               Margin="6,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=QueryBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>
        </Border>

        <!-- 결과 목록 -->
        <ListView x:Name="ResultList"
                  Grid.Row="1"
                  Background="{DynamicResource WindowBackground}"
                  Foreground="{DynamicResource PrimaryText}"
                  BorderThickness="0"
                  MouseDoubleClick="ResultList_MouseDoubleClick"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <Border Padding="6,3"
                                    Background="{DynamicResource SurfaceBackground}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                    <TextBlock Text=" ("
                                               Foreground="{DynamicResource SecondaryText}"/>
                                    <TextBlock Text="{Binding ItemCount}"
                                               Foreground="{DynamicResource SecondaryText}"/>
                                    <TextBlock Text="건)"
                                               Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="줄" Width="50">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding LineNumber}"
                                           Foreground="{DynamicResource SecondaryText}"
                                           HorizontalAlignment="Right"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="내용" Width="500">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding LineText}"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="경로" Width="300">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FolderPath}"
                                           Foreground="{DynamicResource SecondaryText}"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 상태 바 -->
        <Border Grid.Row="2"
                Padding="8,3"
                Background="{DynamicResource SurfaceBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="CancelButton"
                        DockPanel.Dock="Right"
                        Style="{StaticResource CompactToolButtonStyle}"
                        Content="취소"
                        Width="44"
                        Visibility="Collapsed"
                        Click="CancelButton_Click"/>
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryText}"
                           Text="검색어를 입력하고 Enter를 누르세요."/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
