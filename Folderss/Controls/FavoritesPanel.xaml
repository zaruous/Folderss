<UserControl x:Class="Folderss.Controls.FavoritesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Folderss.Models"
             MinWidth="180">
    <Grid Background="{DynamicResource PanelBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Padding="10,8"
                Background="{DynamicResource SurfaceBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="즐겨찾기"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        ToolTip="즐겨찾기 그룹 추가"
                        Width="30"
                        Height="26"
                        Padding="9,3"
                        Margin="0,0,4,0"
                        Click="AddGroup_Click">
                    <Viewbox Width="14" Height="14">
                        <Canvas Width="16" Height="16">
                            <Path Fill="{DynamicResource AccentBrush}"
                                  Data="M1,3 L6,3 L8,5 L15,5 L15,14 L1,14 Z"/>
                            <Path Stroke="{DynamicResource AccentBrush}"
                                  StrokeThickness="2"
                                  Data="M12,0 L12,6 M9,3 L15,3"/>
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button Grid.Column="2"
                        Content="+"
                        ToolTip="현재 폴더 또는 선택한 파일 추가"
                        Width="30"
                        Height="26"
                        Padding="9,3"
                        Click="AddCurrent_Click"/>
            </Grid>
        </Border>

        <TreeView x:Name="FavoritesTree"
                  Grid.Row="1"
                  Background="{DynamicResource PanelBackground}"
                  BorderThickness="0"
                  AllowDrop="True"
                  ContextMenuOpening="FavoritesTree_ContextMenuOpening"
                  PreviewMouseLeftButtonDown="FavoritesTree_PreviewMouseLeftButtonDown"
                  PreviewMouseMove="FavoritesTree_PreviewMouseMove"
                  PreviewMouseRightButtonDown="FavoritesTree_PreviewMouseRightButtonDown"
                  DragOver="FavoritesTree_DragOver"
                  Drop="FavoritesTree_Drop"
                  MouseDoubleClick="FavoritesTree_MouseDoubleClick">
            <TreeView.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="OpenInExplorerMenuItem"
                              Header="Explorer에서 폴더 열기"
                              Click="OpenInExplorer_Click"/>
                    <MenuItem x:Name="OpenTerminalMenuItem"
                              Header="터미널">
                        <MenuItem Header="PowerShell 열기"
                                  Click="OpenPowerShell_Click"/>
                        <MenuItem Header="CMD 열기"
                                  Click="OpenCmd_Click"/>
                    </MenuItem>
                    <MenuItem x:Name="MoveToGroupMenuItem"
                              Header="다른 그룹으로 이동"/>
                    <Separator x:Name="FavoriteActionsSeparator"/>
                    <MenuItem x:Name="NewFolderMenuItem"
                              Header="새 폴더"
                              Click="NewFolder_Click"/>
                    <MenuItem x:Name="NewFileMenuItem"
                              Header="새 파일"
                              Click="NewFile_Click"/>
                    <Separator x:Name="NewItemSeparator"/>
                    <MenuItem x:Name="RenameMenuItem"
                              Header="이름 변경"
                              Click="Rename_Click"/>
                    <MenuItem x:Name="MoveUpMenuItem"
                              Header="위로 이동"
                              Click="MoveUp_Click"/>
                    <MenuItem x:Name="MoveDownMenuItem"
                              Header="아래로 이동"
                              Click="MoveDown_Click"/>
                    <Separator/>
                    <MenuItem x:Name="RemoveMenuItem"
                              Header="삭제"
                              Click="Remove_Click"/>
                </ContextMenu>
            </TreeView.ContextMenu>
            <TreeView.Resources>
                <Style TargetType="{x:Type TreeViewItem}">
                    <Setter Property="IsExpanded" Value="True"/>
                </Style>
                <HierarchicalDataTemplate DataType="{x:Type models:FavoriteGroup}"
                                          ItemsSource="{Binding Favorites}">
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <TextBlock Text="📁" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
                <DataTemplate DataType="{x:Type models:FavoriteLocation}">
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="★"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFile}" Value="True">
                                            <Setter Property="Text" Value="📄"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Path}"
                                       Foreground="{DynamicResource SecondaryText}"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Path}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </TreeView.Resources>
        </TreeView>
    </Grid>
</UserControl>
