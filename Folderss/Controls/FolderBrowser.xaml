<UserControl x:Class="Folderss.Controls.FolderBrowser"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="360"
             Focusable="True"
             Loaded="FolderBrowser_Loaded"
             Unloaded="FolderBrowser_Unloaded"
             GotKeyboardFocus="Pane_GotKeyboardFocus"
             PreviewTextInput="FolderBrowser_PreviewTextInput"
             MouseDown="Pane_MouseDown">
    <Border x:Name="PaneBorder"
            Background="{DynamicResource PanelBackground}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Height="36" Margin="7,5,7,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Style="{StaticResource CompactToolButtonStyle}"
                        Content="←" ToolTip="뒤로" Click="Back_Click"/>
                <Button Grid.Column="1"
                        Style="{StaticResource CompactToolButtonStyle}"
                        Content="→" ToolTip="앞으로" Click="Forward_Click"/>
                <Button Grid.Column="2"
                        Style="{StaticResource CompactToolButtonStyle}"
                        Content="↑" ToolTip="상위 폴더" Click="Up_Click"/>
                <ComboBox x:Name="DriveComboBox"
                          Grid.Column="3"
                          Width="70"
                          Height="28"
                          Margin="5,0,0,0"
                          VerticalContentAlignment="Center"
                          ToolTip="드라이브 선택"
                          SelectionChanged="DriveComboBox_SelectionChanged"/>
                <TextBox x:Name="PathBox"
                         Grid.Column="4"
                         Height="28"
                         Margin="5,0,0,0"
                         Padding="8,3"
                         VerticalContentAlignment="Center"
                         KeyDown="PathBox_KeyDown"/>
            </Grid>

            <Grid Grid.Row="1" Height="34" Margin="8,0,8,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="필터"
                           Width="38"
                           Margin="3,0,5,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryText}"
                           FontSize="12"/>
                <Grid Grid.Column="1" Height="28">
                    <TextBox x:Name="SearchBox"
                             Padding="8,3,28,3"
                             VerticalContentAlignment="Center"
                             ToolTip="현재 폴더에서 이름 필터"
                             PreviewKeyDown="SearchBox_PreviewKeyDown"
                             TextChanged="SearchBox_TextChanged"/>
                    <TextBlock x:Name="SearchHintText"
                               Text="파일 및 폴더 이름"
                               Margin="9,0,30,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource DisabledTextBrush}"
                               IsHitTestVisible="False"/>
                    <Button x:Name="ClearSearchButton"
                            HorizontalAlignment="Right"
                            Style="{StaticResource CompactToolButtonStyle}"
                            Width="26"
                            Height="26"
                            Margin="0,1,1,1"
                            Content="×"
                            FontSize="15"
                            Visibility="Collapsed"
                            ToolTip="필터 지우기"
                            Click="ClearSearch_Click"/>
                </Grid>
                <TextBlock x:Name="FilteredCountText"
                           Grid.Column="2"
                           MinWidth="68"
                           Margin="8,0,4,0"
                           VerticalAlignment="Center"
                           TextAlignment="Right"
                           Foreground="{DynamicResource SecondaryText}"
                           FontSize="11"/>
                <ToggleButton x:Name="ShowHiddenButton"
                              Grid.Column="3"
                              Style="{StaticResource CompactToggleButtonStyle}"
                              Width="42"
                              Height="28"
                              Margin="4,0,0,0"
                              Content="숨김"
                              FontSize="11"
                              ToolTip="숨김 파일 표시/숨기기"
                              Checked="ToggleHidden_Changed"
                              Unchecked="ToggleHidden_Changed"/>
            </Grid>

            <Grid Grid.Row="2" Margin="8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="7*" MinHeight="120"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="3*" MinHeight="120"/>
                </Grid.RowDefinitions>

                <ListView x:Name="FileList"
                          Grid.Row="0"
                          Background="{DynamicResource PanelBackground}"
                          Foreground="{DynamicResource PrimaryText}"
                          BorderThickness="0"
                          AllowDrop="True"
                          SelectionMode="Extended"
                          SelectionChanged="FileList_SelectionChanged"
                          MouseDoubleClick="FileList_MouseDoubleClick"
                          KeyDown="FileList_KeyDown"
                          PreviewMouseLeftButtonDown="FileList_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="FileList_PreviewMouseMove"
                          PreviewMouseRightButtonDown="FileList_PreviewMouseRightButtonDown"
                          MouseRightButtonUp="FileList_MouseRightButtonUp"
                          DragOver="FileList_DragOver"
                          DragLeave="FileList_DragLeave"
                          Drop="FileList_Drop"
                          GotKeyboardFocus="Pane_GotKeyboardFocus">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCut}" Value="True">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="" Width="38" DisplayMemberBinding="{Binding Icon}"/>
                            <GridViewColumn Width="280" DisplayMemberBinding="{Binding Name}">
                                <GridViewColumnHeader Content="이름" Tag="Name"/>
                            </GridViewColumn>
                            <GridViewColumn Width="145" DisplayMemberBinding="{Binding ModifiedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}">
                                <GridViewColumnHeader Content="수정한 날짜" Tag="ModifiedAt"/>
                            </GridViewColumn>
                            <GridViewColumn Width="100" DisplayMemberBinding="{Binding Kind}">
                                <GridViewColumnHeader Content="유형" Tag="Kind"/>
                            </GridViewColumn>
                            <GridViewColumn Width="90" DisplayMemberBinding="{Binding DisplaySize}">
                                <GridViewColumnHeader Content="크기" Tag="Size"/>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <GridSplitter Grid.Row="1"
                              Height="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="{DynamicResource BorderBrush}"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource PanelBackground}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Padding="9,6"
                                    Background="{DynamicResource SurfaceBackground}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <TextBlock Text="내용" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="PreviewSummaryText"
                                               DockPanel.Dock="Right"
                                               Foreground="{DynamicResource SecondaryText}"/>
                                </DockPanel>
                            </Border>
                            <Grid Grid.Row="1">
                                <TextBlock x:Name="PreviewEmptyText"
                                           Text="파일을 선택하면 내용을 미리 볼 수 있습니다."
                                           Foreground="{DynamicResource SecondaryText}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="12"/>
                                <ScrollViewer x:Name="TextPreviewScroll"
                                              Visibility="Collapsed"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto">
                                    <TextBox x:Name="TextPreview"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             TextWrapping="NoWrap"
                                             BorderThickness="0"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             Padding="10"/>
                                </ScrollViewer>
                                <Border x:Name="ImagePreviewContainer"
                                        Visibility="Collapsed"
                                        Padding="8"
                                        Background="{DynamicResource PanelBackground}">
                                    <Image x:Name="ImagePreview"
                                           Stretch="Uniform"
                                           SnapsToDevicePixels="True"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  Width="6"
                                  HorizontalAlignment="Stretch"
                                  Background="{DynamicResource BorderBrush}"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"/>

                    <Border Grid.Column="2"
                            Background="{DynamicResource PanelBackground}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Padding="9,6"
                                    Background="{DynamicResource SurfaceBackground}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <TextBlock Text="선택된 항목과 파일크기(MB단위)" FontWeight="SemiBold"/>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <Grid Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="이름" Foreground="{DynamicResource SecondaryText}" Margin="0,2,8,5"/>
                                    <TextBlock x:Name="MetadataName" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap" Margin="0,2,0,5"/>
                                    <TextBlock Grid.Row="1" Text="형식" Foreground="{DynamicResource SecondaryText}" Margin="0,2,8,5"/>
                                    <TextBlock x:Name="MetadataType" Grid.Row="1" Grid.Column="1" Margin="0,2,0,5"/>
                                    <TextBlock Grid.Row="2" Text="크기" Foreground="{DynamicResource SecondaryText}" Margin="0,2,8,5"/>
                                    <TextBlock x:Name="MetadataSize" Grid.Row="2" Grid.Column="1" Margin="0,2,0,5"/>
                                    <TextBlock Grid.Row="3" Text="생성일자" Foreground="{DynamicResource SecondaryText}" Margin="0,2,8,5"/>
                                    <TextBlock x:Name="MetadataCreated" Grid.Row="3" Grid.Column="1" Margin="0,2,0,5"/>
                                    <TextBlock Grid.Row="4" Text="수정일자" Foreground="{DynamicResource SecondaryText}" Margin="0,2,8,5"/>
                                    <TextBlock x:Name="MetadataModified" Grid.Row="4" Grid.Column="1" Margin="0,2,0,5"/>
                                    <TextBlock Grid.Row="5" Text="권한" Foreground="{DynamicResource SecondaryText}" Margin="0,2,8,5"/>
                                    <TextBlock x:Name="MetadataPermissions" Grid.Row="5" Grid.Column="1" TextWrapping="Wrap" Margin="0,2,0,5"/>
                                    <TextBlock Grid.Row="6" Text="특성" Foreground="{DynamicResource SecondaryText}" Margin="0,2,8,5"/>
                                    <TextBlock x:Name="MetadataAttributes" Grid.Row="6" Grid.Column="1" TextWrapping="Wrap" Margin="0,2,0,5"/>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="3"
                    Margin="8"
                    Padding="8,5"
                    Background="{DynamicResource ControlBackground}"
                    CornerRadius="3">
                <TextBlock x:Name="StatusText" Foreground="{DynamicResource SecondaryText}"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
