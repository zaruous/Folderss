<Window x:Class="Folderss.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Folderss.Controls"
        xmlns:avalon="clr-namespace:AvalonDock;assembly=AvalonDock"
        xmlns:layout="clr-namespace:AvalonDock.Layout;assembly=AvalonDock"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Folderss"
        Icon="app.ico"
        Width="1400"
        Height="820"
        MinWidth="900"
        MinHeight="560"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        PreviewKeyDown="Window_PreviewKeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Height="36"
                Background="{DynamicResource SurfaceBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <Border Width="20"
                            Height="20"
                            Margin="0,0,8,0"
                            Background="{DynamicResource AccentBrush}"
                            CornerRadius="4">
                        <TextBlock Text="F"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Folderss"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button x:Name="MainMenuButton"
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Style="{StaticResource CompactToolButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Content="⋯"
                        FontSize="18"
                        ToolTip="메뉴"
                        Click="MainMenuButton_Click">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="MainContextMenu">
                            <MenuItem Header="폴더 패널 추가..." InputGestureText="Ctrl+T" Click="AddFolderPanel_Click"/>
                            <MenuItem Header="새 폴더" InputGestureText="Ctrl+Shift+N" Click="NewFolder_Click"/>
                            <Separator/>
                            <MenuItem Header="이름 변경" InputGestureText="F2" Click="Rename_Click"/>
                            <MenuItem Header="휴지통으로 이동" InputGestureText="Delete" Click="Delete_Click"/>
                            <Separator/>
                            <MenuItem Header="새로 고침" InputGestureText="Ctrl+R" Click="Refresh_Click"/>
                            <MenuItem Header="보기">
                                <MenuItem Header="파일 내용 검색" InputGestureText="Ctrl+F" Click="ShowSearch_Click"/>
                                <MenuItem Header="즐겨찾기 표시" Click="ShowFavorites_Click"/>
                                <Separator/>
                                <MenuItem Header="기본 도킹 배치로 초기화" Click="ResetDockLayout_Click"/>
                            </MenuItem>
                            <MenuItem Header="테마">
                                <MenuItem x:Name="BlackThemeMenuItem"
                                          Header="블랙 테마"
                                          IsCheckable="True"
                                          Click="BlackTheme_Click"/>
                                <MenuItem x:Name="LightThemeMenuItem"
                                          Header="라이트 테마"
                                          IsCheckable="True"
                                          Click="LightTheme_Click"/>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="Folderss 정보" Click="About_Click"/>
                            <MenuItem Header="종료" Click="Exit_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Content="—"
                            ToolTip="최소화"
                            Click="Minimize_Click"/>
                    <Button x:Name="MaximizeButton"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Content="□"
                            ToolTip="최대화"
                            Click="MaximizeRestore_Click"/>
                    <Button Style="{StaticResource TitleBarCloseButtonStyle}"
                            Content="×"
                            ToolTip="닫기"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <avalon:DockingManager x:Name="DockManager"
                               Grid.Row="1"
                               Margin="6"
                               Background="{DynamicResource WindowBackground}">
            <layout:LayoutRoot>
                <layout:LayoutPanel Orientation="Vertical">
                    <layout:LayoutPanel Orientation="Horizontal">
                        <layout:LayoutAnchorablePane DockWidth="230">
                            <layout:LayoutAnchorable x:Name="FavoritesDock"
                                                     Title="즐겨찾기"
                                                     ContentId="favorites"
                                                     CanClose="True"
                                                     CanHide="True"
                                                     CanAutoHide="True">
                                <controls:FavoritesPanel x:Name="FavoritesPanel"
                                                         AddCurrentRequested="FavoritesPanel_AddCurrentRequested"
                                                         NavigateRequested="FavoritesPanel_NavigateRequested"/>
                            </layout:LayoutAnchorable>
                        </layout:LayoutAnchorablePane>
                        <layout:LayoutDocumentPaneGroup>
                            <layout:LayoutDocumentPane>
                                <layout:LayoutDocument Title="왼쪽 폴더"
                                                       ContentId="left-folder"
                                                       CanClose="False">
                                    <controls:FolderBrowser x:Name="LeftPane" Activated="Pane_Activated"/>
                                </layout:LayoutDocument>
                                <layout:LayoutDocument Title="＋ 새 패널"
                                                       ContentId="add-folder-panel"
                                                       CanClose="False"/>
                            </layout:LayoutDocumentPane>
                            <layout:LayoutDocumentPane>
                                <layout:LayoutDocument Title="오른쪽 폴더"
                                                       ContentId="right-folder"
                                                       CanClose="False">
                                    <controls:FolderBrowser x:Name="RightPane" Activated="Pane_Activated"/>
                                </layout:LayoutDocument>
                            </layout:LayoutDocumentPane>
                        </layout:LayoutDocumentPaneGroup>
                    </layout:LayoutPanel>
                </layout:LayoutPanel>
            </layout:LayoutRoot>
        </avalon:DockingManager>

        <Border Grid.Row="2"
                Margin="6,0,6,6"
                Padding="8,4"
                Background="{DynamicResource SurfaceBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="5">
            <DockPanel>
                <TextBlock x:Name="ActivePaneText"
                           DockPanel.Dock="Left"
                           Foreground="{DynamicResource SecondaryText}"/>
                <TextBlock DockPanel.Dock="Right"
                           Text="F2 이름변경 · F5 복사 · F6 이동 · Del 삭제 · Ctrl+C/V 클립보드 · Alt+←/→ 뒤로/앞으로 · Alt+↑ 상위폴더 · Ctrl+Shift+←/→ 패널전환 · Ctrl+T 패널추가 · Ctrl+F 내용검색 · 패널 드래그로 상하좌우 배치"
                           Foreground="{DynamicResource SecondaryText}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
