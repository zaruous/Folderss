<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <FontFamily x:Key="AppFontFamily">Segoe UI</FontFamily>

    <Color x:Key="WindowBackgroundColor">#242831</Color>
    <Color x:Key="PanelBackgroundColor">#2E3440</Color>
    <Color x:Key="SurfaceBackgroundColor">#3B4252</Color>
    <Color x:Key="ControlBackgroundColor">#434C5E</Color>
    <Color x:Key="ControlHoverColor">#4C566A</Color>
    <Color x:Key="ControlPressedColor">#575F6E</Color>
    <Color x:Key="BorderColor">#434C5E</Color>
    <Color x:Key="PrimaryTextColor">#ECEFF4</Color>
    <Color x:Key="SecondaryTextColor">#D8DEE9</Color>
    <Color x:Key="DisabledTextColor">#616E88</Color>
    <Color x:Key="AccentColor">#88C0D0</Color>
    <Color x:Key="AccentHoverColor">#9ECFDE</Color>
    <Color x:Key="SelectionColor">#3B5270</Color>
    <Color x:Key="RowHoverColor">#323A49</Color>

    <SolidColorBrush x:Key="WindowBackground" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBackground" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBackground" Color="{StaticResource SurfaceBackgroundColor}"/>
    <SolidColorBrush x:Key="ControlBackground" Color="{StaticResource ControlBackgroundColor}"/>
    <SolidColorBrush x:Key="ControlHoverBrush" Color="{StaticResource ControlHoverColor}"/>
    <SolidColorBrush x:Key="ControlPressedBrush" Color="{StaticResource ControlPressedColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="PrimaryText" Color="{StaticResource PrimaryTextColor}"/>
    <SolidColorBrush x:Key="SecondaryText" Color="{StaticResource SecondaryTextColor}"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource DisabledTextColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource SelectionColor}"/>
    <SolidColorBrush x:Key="RowHoverBrush" Color="{StaticResource RowHoverColor}"/>

    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="{StaticResource PrimaryTextColor}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="{StaticResource ControlBackgroundColor}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="{StaticResource PrimaryTextColor}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="{StaticResource SurfaceBackgroundColor}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="{StaticResource PrimaryTextColor}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{StaticResource SelectionColor}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{StaticResource PrimaryTextColor}"/>
</ResourceDictionary>
