<Window x:Class="Folderss.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Width="720"
        Height="540"
        MinWidth="580"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main content: left nav + right panel -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left navigation -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBackground}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <ListBox x:Name="TabNav"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="6,8"
                         SelectionChanged="TabNav_SelectionChanged">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,9"/>
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                    <Condition Property="IsSelected" Value="False"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.Resources>

                    <ListBoxItem Tag="Shortcuts">
                        <TextBlock Text="단축키"/>
                    </ListBoxItem>
                    <ListBoxItem Tag="Theme">
                        <TextBlock Text="테마"/>
                    </ListBoxItem>
                </ListBox>
            </Border>

            <!-- Right content area -->
            <Grid Grid.Column="1">

                <!-- Theme panel -->
                <Grid x:Name="ThemePanel" Margin="24,16" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="테마 설정"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20"/>

                    <StackPanel Grid.Row="1" Orientation="Vertical">
                        <RadioButton x:Name="BlackThemeRadio"
                                     GroupName="AppTheme"
                                     Margin="0,0,0,14"
                                     Checked="ThemeRadio_Checked"
                                     Tag="Black">
                            <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                                <Border Width="28" Height="28"
                                        CornerRadius="4"
                                        Background="#08090B"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0"/>
                                <TextBlock Text="블랙 테마" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="LightThemeRadio"
                                     GroupName="AppTheme"
                                     Checked="ThemeRadio_Checked"
                                     Tag="Light">
                            <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                                <Border Width="28" Height="28"
                                        CornerRadius="4"
                                        Background="#EEF1F5"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0"/>
                                <TextBlock Text="라이트 테마" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Grid>

                <!-- Shortcuts panel -->
                <Grid x:Name="ShortcutsPanel" Margin="24,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="단축키 설정"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <ListView x:Name="ShortcutList"
                              Grid.Row="1"
                              SelectionMode="Single"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource BorderBrush}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="작업" Width="200" DisplayMemberBinding="{Binding DisplayName}"/>
                                <GridViewColumn Header="단축키" Width="160" DisplayMemberBinding="{Binding KeyDisplayText}"/>
                                <GridViewColumn Header="" Width="74">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="변경"
                                                    Click="ChangeBinding_Click"
                                                    Padding="8,3"
                                                    Margin="0"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Button Grid.Row="2"
                            Content="기본값으로 초기화"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0"
                            Click="ResetDefaults_Click"/>
                </Grid>

            </Grid>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="1"
                Padding="16,10"
                Background="{DynamicResource SurfaceBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="저장" Click="Save_Click" MinWidth="80" Margin="0,0,8,0"/>
                <Button Content="취소" Click="Cancel_Click" MinWidth="80" IsCancel="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
